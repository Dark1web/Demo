# =============================================================================
# AEGIS VISION BACKEND CONFIGURATION
# =============================================================================

# Database Configuration (Supabase)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Python API Configuration
PYTHON_API_PORT=8000
PYTHON_API_TOKEN=your_secure_api_token

# Node.js Data Pipeline Configuration
NODE_PIPELINE_PORT=3001
FRONTEND_URL=http://localhost:8080

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# Weather APIs
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_API_KEY=your_weather_api_key

# Social Media APIs
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
MASTODON_ACCESS_TOKEN=your_mastodon_access_token
MASTODON_INSTANCE=mastodon.social

# News APIs
NEWS_API_KEY=your_news_api_key
GUARDIAN_API_KEY=your_guardian_api_key

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Webhook URLs
SLACK_WEBHOOK_URL=your_slack_webhook_url
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# =============================================================================
# SECURITY & PERFORMANCE
# =============================================================================

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key
JWT_EXPIRE_TIME=24h

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# =============================================================================
# ENVIRONMENT
# =============================================================================

NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# MACHINE LEARNING
# =============================================================================

# Model paths (optional)
FLOOD_MODEL_PATH=./models/flood_model.joblib
MISINFO_MODEL_PATH=./models/misinfo_model.joblib

# Hugging Face (for transformer models)
HUGGINGFACE_API_KEY=your_huggingface_api_key

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Sentry for error tracking (optional)
SENTRY_DSN=your_sentry_dsn

# Analytics
ANALYTICS_KEY=your_analytics_key